#!/bin/bash
set -euo pipefail

COLORS=~/.config/noctalia/colors.json
ICON_SRC=/usr/share/icons/Papirus-Dark
ICON_DST=~/.local/share/icons/noctalia-folders

PRIMARY=$(jq -r '.mPrimary' "$COLORS")
ON_PRIMARY=$(jq -r '.mOnPrimary' "$COLORS")

DARK=$(python3 -c "
c = '$PRIMARY'.lstrip('#')
r, g, b = int(c[0:2],16), int(c[2:4],16), int(c[4:6],16)
r, g, b = int(r*0.8), int(g*0.8), int(b*0.8)
print(f'#{r:02x}{g:02x}{b:02x}')
")

for src in "$ICON_SRC"/*/places/folder-blue*.svg "$ICON_SRC"/*/places/user-blue*.svg; do
    [[ -f "$src" ]] || continue
    size=$(echo "$src" | grep -oP '\d+x\d+(@\d+x)?')
    basename=$(basename "$src")
    dst_dir="$ICON_DST/$size/places"
    mkdir -p "$dst_dir"

    sed "s/#5294e2/$PRIMARY/g; s/#4877b1/$DARK/g; s/#1d344f/$ON_PRIMARY/g" "$src" > "$dst_dir/$basename"

    # Symlink: folder-blue-pictures.svg -> folder-pictures.svg etc.
    symlink="${basename//-blue/}"
    ln -sf "$basename" "$dst_dir/$symlink"
done

gtk4-update-icon-cache -f -t "$ICON_DST" 2>/dev/null || true

gsettings set org.gnome.desktop.interface icon-theme 'noctalia-folders'
